{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "**Projet :** TaskFlow application de gestion de tâches<br> **Version :** 1.0",
  "main": "back/src/server.js",
  "scripts": {
    "start": "node back/src/server.js",
    "dev": "nodemon back/src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "back/src/**/*.js",
      "!back/src/app.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testTimeout": 10000
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YcafardyDiginamic/TaskFlow.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/YcafardyDiginamic/TaskFlow/issues"
  },
  "homepage": "https://github.com/YcafardyDiginamic/TaskFlow#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "madge": "^8.0.0",
    "mongoose": "^9.3.0",
    "moran": "^0.0.11",
    "morgan": "^1.10.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
